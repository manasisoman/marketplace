# .envrc — loaded automatically by direnv
# ─────────────────────────────────────────────────────────────────
# HOW THIS WORKS:
#   Local dev  → values come from backend/.env (gitignored)
#   Devin / CI → values injected via Devin secrets manager
# ─────────────────────────────────────────────────────────────────

# Load secrets from backend/.env when running locally
dotenv_if_exists backend/.env

# ── Required secrets (set these in Devin's secrets manager) ──────
# MONGO_URI  — MongoDB Atlas connection string
#              e.g. mongodb+srv://user:pass@cluster.mongodb.net/dbname

# ── Application config (safe to commit) ──────────────────────────
export PORT="${PORT:-3001}"
